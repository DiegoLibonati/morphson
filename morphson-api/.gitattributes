# Force LF for shell scripts and dotfiles that are executed inside Linux containers.
# Without this, a Windows checkout would write CRLF, and Linux `exec` would fail with
# "no such file or directory" on the shebang line.

* text=auto eol=lf

*.sh           text eol=lf
*.bash         text eol=lf
Dockerfile*    text eol=lf
.githooks/*    text eol=lf
entrypoint.*   text eol=lf

# Treat lockfiles as text but keep them LF to avoid noisy diffs across OSes.
package-lock.json text eol=lf
requirements*.txt text eol=lf

# Binaries — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf
*.pdf   binary
*.zip   binary
*.gz    binary